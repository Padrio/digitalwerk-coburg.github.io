---
import BaseLayout from './BaseLayout.astro';
import Header from '@components/navigation/Header.astro';
import Footer from '@components/footer/Footer.astro';
import Breadcrumbs from '@components/navigation/Breadcrumbs.astro';
import ScrollToTop from '@components/ui/ScrollToTop.astro';
import CTASticky from '@components/ui/CTASticky.astro';
import WhatsAppButton from '@components/ui/WhatsAppButton.astro';
import CookieBanner from '@components/ui/CookieBanner.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import { buildBreadcrumbs, type BreadcrumbItem } from '@utils/seo';
import { buildBreadcrumbList, buildLocalBusiness, buildWebSite } from '@utils/schema';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noIndex?: boolean;
  ogImage?: string;
  ogType?: string;
  showBreadcrumbs?: boolean;
  breadcrumbs?: BreadcrumbItem[];
  articlePublishedTime?: string;
  articleModifiedTime?: string;
}

const {
  title,
  description,
  canonical,
  noIndex,
  ogImage,
  ogType,
  showBreadcrumbs = true,
  breadcrumbs,
  articlePublishedTime,
  articleModifiedTime,
} = Astro.props;

const breadcrumbItems = breadcrumbs ?? buildBreadcrumbs(Astro.url.pathname);
const cleanPathname = Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '') || '/';
const isHome = cleanPathname === '/';
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  noIndex={noIndex}
  ogImage={ogImage}
  ogType={ogType}
  articlePublishedTime={articlePublishedTime}
  articleModifiedTime={articleModifiedTime}
>
  <slot name="head" slot="head" />

  <Header />

  {showBreadcrumbs && !isHome && (
    <div class="container py-4">
      <Breadcrumbs items={breadcrumbItems} />
    </div>
  )}

  <main class="flex-1">
    <slot />
  </main>

  <Footer />

  <ScrollToTop />
  <CTASticky />
  <WhatsAppButton />
  <CookieBanner />

  <JsonLd schema={buildLocalBusiness()} />
  <JsonLd schema={buildWebSite()} />
  {showBreadcrumbs && !isHome && (
    <JsonLd schema={buildBreadcrumbList(breadcrumbItems)} />
  )}
</BaseLayout>
