---
import PageLayout from '@layouts/PageLayout.astro';
import { buildSeoMeta } from '@utils/seo';
import { SITE } from '@data/site';
import JsonLd from '@components/seo/JsonLd.astro';
import { buildPerson, buildProfilePage } from '@utils/schema';

import Hero from '@components/sections/Hero.astro';
import CTA from '@components/ui/CTA.astro';

import { Gem, Eye, Handshake, Briefcase, GraduationCap, Rocket, Users, Building2 } from 'lucide-astro';
import IsometricBlocks from '@components/decorative/IsometricBlocks.astro';
import GridPattern from '@components/decorative/GridPattern.astro';

const seo = buildSeoMeta({
  title: 'Über mich',
  description:
    'Pascal Krason – Gründer von Digitalwerk Coburg. Über 10 Jahre Erfahrung in Webentwicklung und digitaler Strategie, von CHECK24 bis zur eigenen Unternehmensgründung.',
});

const values = [
  {
    icon: Gem,
    title: 'Qualität',
    description:
      'Lieber weniger Projekte, dafür richtig gut. Ich nehme mir die Zeit, die es braucht, um Ergebnisse zu liefern, hinter denen ich voll und ganz stehe. Sauberer Code, durchdachtes Design und eine solide technische Basis sind für mich keine Kür, sondern Pflicht.',
  },
  {
    icon: Eye,
    title: 'Transparenz',
    description:
      'Sie wissen immer, wo Ihr Projekt steht, was als Nächstes passiert und was es braucht. Keine versteckten Gebühren, keine bösen Überraschungen. Transparente Angebote, regelmäßige Updates und ehrliche Kommunikation – so entsteht Vertrauen.',
  },
  {
    icon: Handshake,
    title: 'Partnerschaft',
    description:
      'Ich bin nicht nur Dienstleister, sondern Ihr digitaler Sparringspartner. Mir ist wichtig, dass Sie nicht nur ein fertiges Produkt bekommen, sondern auch verstehen, wie es funktioniert. Langfristige Zusammenarbeit auf Augenhöhe ist mein Ziel.',
  },
];

const techStack = [
  'Astro',
  'React',
  'TypeScript',
  'Tailwind CSS',
  'Node.js',
  'Laravel',
  'WordPress',
  'Shopify',
  'Docker',
  'Kubernetes',
  'Figma',
  'Supabase',
  'Git',
  'Vercel',
  'Cloudflare',
];

const milestones = [
  {
    icon: GraduationCap,
    year: '2014–2017',
    title: 'Ausbildung zum Anwendungsentwickler',
    description:
      'Fundierte Grundlage in Softwareentwicklung und IT-Infrastruktur – der Startpunkt meiner digitalen Karriere.',
  },
  {
    icon: Building2,
    year: '2017–2019',
    title: 'Entwickler bei CHECK24',
    description:
      'Als Entwickler bei Deutschlands größtem Vergleichsportal habe ich an der Plattform mitgearbeitet, die täglich Millionen Nutzer bedient – und dabei gelernt, was es bedeutet, digitale Produkte zu bauen, die wirklich funktionieren.',
  },
  {
    icon: Rocket,
    year: '2019–2023',
    title: 'Gründung eigene E-Commerce-Marke',
    description:
      'Mit AP Supplements habe ich eine eigene Marke aufgebaut – vom Online-Shop über Logistik bis zum Marketing. Diese Erfahrung als Unternehmer hilft mir heute, die Perspektive meiner Kunden wirklich zu verstehen.',
  },
  {
    icon: Users,
    year: '2022–2024',
    title: 'Software Engineer & Teamleitung',
    description:
      'Bei PohlMedia habe ich SaaS-Produkte entwickelt, ein Entwicklerteam geleitet und Projekte im Gesundheitswesen und Industrieumfeld verantwortet.',
  },
  {
    icon: Briefcase,
    year: 'Seit 2024',
    title: 'Gründung Digitalwerk Coburg',
    description:
      'Persönliche Digitalberatung für Unternehmen in der Region Coburg und Oberfranken. Die Summe meiner Erfahrungen – gebündelt in einem Angebot, das auf Ihre Bedürfnisse zugeschnitten ist.',
  },
];
---

<PageLayout
  title={seo.title}
  description={seo.description}
  ogImage={seo.ogImage}
  ogType={seo.ogType}
>
  {/* Person & ProfilePage JSON-LD */}
  <JsonLd schema={buildPerson()} />
  <JsonLd schema={buildProfilePage()} />

  {/* 1. Hero */}
  <Hero
    variant="centered"
    badge="Über mich"
    headline="Hallo, ich bin Pascal Krason"
    subheadline="Gründer von Digitalwerk Coburg – über 10 Jahre Erfahrung in Webentwicklung und digitaler Strategie. Ihr persönlicher Ansprechpartner für alle digitalen Fragen."
  />

  {/* 2. Zahlen/Fakten */}
  <section class="border-y border-neutral-200 bg-white py-10">
    <div class="container">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        <div class="text-center">
          <p class="font-display text-3xl font-bold text-accent">10+</p>
          <p class="mt-1 text-sm text-neutral-600">Jahre Erfahrung</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-bold text-accent">2</p>
          <p class="mt-1 text-sm text-neutral-600">eigene Unternehmen gegründet</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-bold text-accent">4+</p>
          <p class="mt-1 text-sm text-neutral-600">Branchen betreut</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-bold text-accent">Coburg</p>
          <p class="mt-1 text-sm text-neutral-600">Standort in Oberfranken</p>
        </div>
      </div>
    </div>
  </section>

  {/* 3. Personal section */}
  <section class="section">
    <div class="container">
      <div class="grid items-start gap-12 lg:grid-cols-2">
        {/* Left: Visual */}
        <div class="flex items-center justify-center">
          <IsometricBlocks class="w-full max-w-md" />
        </div>

        {/* Right: Story */}
        <div>
          <h2 class="font-display text-2xl font-bold text-primary">
            Warum Digitalwerk?
          </h2>

          <p class="mt-6 text-neutral-600 leading-relaxed">
            Seit über zehn Jahren beschäftige ich mich professionell mit Webentwicklung,
            Webdesign und digitaler Strategie. Mein Weg hat mich von der Ausbildung zum
            Anwendungsentwickler über eine Position bei CHECK24 &ndash; Deutschlands größtem
            Vergleichsportal &ndash; bis hin zur Gründung eigener Unternehmen geführt.
            Dabei habe ich in Unternehmen unterschiedlicher Größe gearbeitet: vom Startup
            bis zum Konzern mit Millionen täglicher Nutzer.
          </p>

          <p class="mt-4 text-neutral-600 leading-relaxed">
            Diese Erfahrung bringe ich in jedes Projekt ein. Als ehemaliger Gründer einer
            eigenen E-Commerce-Marke weiß ich aus erster Hand, welche Herausforderungen
            Unternehmer täglich meistern. Ich verstehe nicht nur die technische Seite,
            sondern auch die unternehmerische &ndash; was funktioniert, was Kunden
            überzeugt und wo Budgets sinnvoll eingesetzt sind.
          </p>

          <p class="mt-4 text-neutral-600 leading-relaxed">
            Digitalwerk Coburg habe ich gegründet, um genau die Zusammenarbeit anzubieten,
            die ich mir als Kunde selbst wünschen würde: persönlich, transparent und auf
            Augenhöhe. Kein anonymes Ticket-System, kein Weiterreichen zwischen Abteilungen
            &ndash; sondern ein fester Ansprechpartner, der Ihr Projekt von der ersten Idee
            bis zum fertigen Ergebnis begleitet.
          </p>

          <p class="mt-4 text-neutral-600 leading-relaxed">
            Ich arbeite bewusst als Einzelunternehmer, weil ich davon überzeugt bin,
            dass die besten Ergebnisse entstehen, wenn eine Person den gesamten Prozess
            versteht und verantwortet. Das bedeutet: kurze Entscheidungswege, schnelle
            Umsetzung und ein Ergebnis, bei dem Design, Technik und Inhalt wie aus
            einem Guss zusammenpassen.
          </p>

          <p class="mt-4 text-neutral-600 leading-relaxed">
            Mein Standort in Coburg ist dabei kein Zufall. Ich kenne die Region, die
            Menschen und die Herausforderungen lokaler Unternehmen. Ob Handwerksbetrieb,
            Arztpraxis oder Mittelständler &ndash; ich spreche Ihre Sprache und verstehe,
            was Sie brauchen, um online erfolgreich zu sein.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* 4. Mein Werdegang */}
  <section class="section bg-neutral-100">
    <div class="container">
      <div class="mx-auto max-w-3xl text-center">
        <h2>Mein Werdegang</h2>
        <p class="mt-4 text-lg text-neutral-600 leading-relaxed">
          Von der Ausbildung über Deutschlands größtes Vergleichsportal bis zur eigenen
          Unternehmensgründung &ndash; die wichtigsten Stationen meiner beruflichen Laufbahn.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-3xl">
        <div class="relative space-y-8 before:absolute before:left-6 before:top-0 before:h-full before:w-px before:bg-neutral-300 md:before:left-8">
          {milestones.map((m) => {
            const IconComponent = m.icon;
            return (
              <div class="relative flex gap-5 md:gap-6">
                <div class="relative z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-white shadow-md ring-1 ring-neutral-200 md:h-16 md:w-16">
                  <IconComponent class="h-5 w-5 text-accent md:h-6 md:w-6" />
                </div>
                <div class="pt-1">
                  <span class="inline-block rounded-full bg-accent/10 px-3 py-0.5 font-display text-small font-semibold text-accent">
                    {m.year}
                  </span>
                  <h3 class="mt-2 font-display text-lg font-semibold text-primary">
                    {m.title}
                  </h3>
                  <p class="mt-1 text-neutral-600 leading-relaxed">
                    {m.description}
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  {/* 5. Values */}
  <section class="section relative bg-neutral-100 overflow-hidden">
    <GridPattern variant="dots" class="absolute inset-0" />
    <div class="container relative z-10">
      <div class="mx-auto max-w-3xl text-center">
        <h2>Meine Werte</h2>
        <p class="mt-4 text-lg text-neutral-600 leading-relaxed">
          Drei Prinzipien, die jede Zusammenarbeit prägen &ndash; und die
          dafür sorgen, dass am Ende ein Ergebnis steht, das wirklich passt.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {values.map((v) => {
          const IconComponent = v.icon;
          return (
            <div class="card flex flex-col items-center p-8 text-center">
              <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-accent/10 text-accent">
                <IconComponent class="h-7 w-7" />
              </div>
              <h3 class="font-display text-xl font-semibold text-primary">
                {v.title}
              </h3>
              <p class="mt-3 text-neutral-600 leading-relaxed">
                {v.description}
              </p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  {/* 6. Tech Stack */}
  <section class="section">
    <div class="container">
      <div class="mx-auto max-w-3xl text-center">
        <h2>Technologien &amp; Tools</h2>
        <p class="mt-4 text-lg text-neutral-600 leading-relaxed">
          Ich arbeite mit modernen, bewährten Technologien &ndash; ausgewählt nach
          den Anforderungen Ihres Projekts, nicht nach persönlichen Vorlieben.
        </p>
      </div>

      <div class="mx-auto mt-12 flex max-w-3xl flex-wrap items-center justify-center gap-4">
        {techStack.map((tech) => (
          <span class="inline-flex items-center rounded-full border border-neutral-300 bg-white px-5 py-2 font-display text-sm font-medium text-primary shadow-sm">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </section>

  {/* 7. Local section */}
  <section class="section bg-neutral-100">
    <div class="container">
      <div class="mx-auto max-w-3xl text-center">
        <h2>Verwurzelt in Coburg</h2>
        <p class="mt-6 text-lg text-neutral-600 leading-relaxed">
          Digitalwerk ist kein anonymes Unternehmen aus der Ferne. Ich arbeite direkt
          in Coburg, mitten in Oberfranken. Das bedeutet: persönliche Treffen sind
          jederzeit möglich, ich kenne die Region und verstehe die besonderen
          Anforderungen lokaler Unternehmen. Ob Stammtisch oder Strategiegespräch
          &ndash; bei mir bekommen Sie beides.
        </p>
      </div>
    </div>
  </section>

  {/* 8. CTA */}
  <CTA
    headline="Lernen wir uns kennen"
    subline="Sie suchen einen zuverlässigen Digitalpartner in Coburg? Ich freue mich auf ein unverbindliches Erstgespräch."
  />
</PageLayout>
