---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import { buildSeoMeta } from '@utils/seo';
import Hero from '@components/sections/Hero.astro';
import BlogPostCard from '@components/ui/BlogPostCard.astro';
import CTA from '@components/ui/CTA.astro';

const seo = buildSeoMeta({
  title: 'Blog',
  description:
    'Praxiswissen rund um Webdesign, Webentwicklung, SEO und KI-Beratung. Tipps und Einblicke von Digitalwerk Coburg für Unternehmen in der Region.',
});

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<PageLayout
  title={seo.title}
  description={seo.description}
  ogImage={seo.ogImage}
  ogType={seo.ogType}
>
  <Hero
    variant="centered"
    badge="Blog"
    headline="Wissen, das weiterbringt"
    subheadline="Praxisnahe Artikel rund um Webdesign, Webentwicklung, SEO und Digitalisierung — speziell für Unternehmen aus der Region Coburg und Oberfranken."
  />

  <section class="section">
    <div class="container">
      {posts.length > 0 ? (
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <BlogPostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id}
              heroImage={post.data.heroImage}
              tags={post.data.tags}
            />
          ))}
        </div>
      ) : (
        <div class="mx-auto max-w-2xl text-center py-16">
          <p class="text-lg text-neutral-600 leading-relaxed">
            Bald erscheinen hier Artikel rund um Webdesign, SEO, Webentwicklung
            und Digitalisierung. Schauen Sie in Kürze wieder vorbei!
          </p>
        </div>
      )}
    </div>
  </section>

  <CTA
    headline="Individuelle Beratung gewünscht?"
    subline="Sie haben Fragen zu einem Thema oder möchten wissen, wie Digitalwerk Coburg Ihnen helfen kann? Vereinbaren Sie ein kostenloses Erstgespräch."
  />
</PageLayout>
