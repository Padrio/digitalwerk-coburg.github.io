---
import PageLayout from '@layouts/PageLayout.astro';
import { getServiceBySlug } from '@data/services';
import { serviceFaqs } from '@data/faqs';
import { buildSeoMeta } from '@utils/seo';
import { buildService, buildFaqPage } from '@utils/schema';
import JsonLd from '@components/seo/JsonLd.astro';
import Hero from '@components/sections/Hero.astro';
import FAQ from '@components/sections/FAQ.astro';
import CTA from '@components/ui/CTA.astro';
import { CheckCircle } from 'lucide-astro';
import GridPattern from '@components/decorative/GridPattern.astro';

const service = getServiceBySlug('ki-beratung')!;
const faqs = serviceFaqs['ki-beratung'] || [];

const seo = buildSeoMeta({
  title: 'KI-Beratung Coburg',
  description:
    'KI-Beratung aus Coburg: Künstliche Intelligenz praxisnah einsetzen. Potenzialanalyse, Chatbot-Entwicklung, Automatisierung und Team-Schulungen für Ihr Unternehmen.',
});
---

<PageLayout title={seo.title} description={seo.description}>
  <JsonLd schema={buildService({ name: service.shortTitle, description: service.description, url: service.href })} />
  <JsonLd schema={buildFaqPage(faqs)} />

  <!-- Hero -->
  <Hero
    badge={service.shortTitle}
    headline={service.title}
    subheadline={service.description}
    primaryCta={{ text: 'Jetzt anfragen', href: '/kontakt' }}
  />

  <!-- Features -->
  <section class="section">
    <div class="container">
      <span class="section-label">Was Sie bekommen</span>
      <h2 class="mb-12">Leistungen im Detail</h2>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {service.features.map((feature, index) => (
          <div class="card">
            <span class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 font-display text-lg font-bold text-accent">
              {String(index + 1).padStart(2, '0')}
            </span>
            <h3 class="mb-2">{feature.title}</h3>
            <p class="text-neutral-600 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- USPs -->
  <section class="section relative bg-neutral-100 overflow-hidden">
    <GridPattern variant="dots" class="absolute inset-0" />
    <div class="container relative z-10">
      <div class="mx-auto max-w-3xl">
        <span class="section-label">Warum Digitalwerk</span>
        <h2 class="mb-10">Ihre Vorteile</h2>

        <ul class="space-y-4">
          {service.usps.map((usp) => (
            <li class="flex items-start gap-3">
              <CheckCircle class="mt-0.5 h-6 w-6 shrink-0 text-success" />
              <span class="text-lg">{usp}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Deliverables -->
  <section class="section">
    <div class="container">
      <div class="mx-auto max-w-3xl">
        <span class="section-label">Lieferumfang</span>
        <h2 class="mb-4">Das ist im Paket enthalten</h2>

        <span class="mb-4 inline-block rounded-full bg-accent/10 px-4 py-1.5 font-display text-sm font-semibold text-accent">
          {service.ctaText}
        </span>
        <a href="/kontakt" class="mb-8 inline-block text-sm font-semibold text-accent hover:underline">
          Jetzt Angebot besprechen &rarr;
        </a>

        <ul class="space-y-3">
          {service.deliverables.map((item) => (
            <li class="flex items-start gap-3">
              <CheckCircle class="mt-0.5 h-5 w-5 shrink-0 text-accent" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-neutral-100">
    <div class="container">
      <FAQ title={`Häufige Fragen zu ${service.shortTitle}`} items={faqs} />
    </div>
  </section>

  <!-- CTA -->
  <CTA
    headline="Bereit, KI in Ihrem Unternehmen einzusetzen?"
    subline="Finden Sie heraus, wie Künstliche Intelligenz Ihre Prozesse effizienter macht. Praxisnah, verständlich und auf Ihr Unternehmen zugeschnitten."
  />
</PageLayout>
