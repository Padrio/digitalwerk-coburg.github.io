---
import PageLayout from '@layouts/PageLayout.astro';
import { getServiceBySlug } from '@data/services';
import { serviceFaqs } from '@data/faqs';
import { buildSeoMeta } from '@utils/seo';
import { buildService, buildFaqPage } from '@utils/schema';
import { getServicePricing } from '@data/service-pricing';
import JsonLd from '@components/seo/JsonLd.astro';
import Hero from '@components/sections/Hero.astro';
import FAQ from '@components/sections/FAQ.astro';
import PricingTiers from '@components/sections/PricingTiers.astro';
import CTA from '@components/ui/CTA.astro';
import { CheckCircle } from 'lucide-astro';
import GridPattern from '@components/decorative/GridPattern.astro';

const service = getServiceBySlug('seo')!;
const faqs = serviceFaqs['seo'] || [];
const pricing = getServicePricing('seo')!;

const seo = buildSeoMeta({
  title: 'SEO — der Service im Überblick',
  description:
    'SEO aus Coburg: Audit ab 1.500 €, Local-SEO-Betreuung ab 600 €/Monat, Full-Service ab 1.500 €/Monat. Spezialisiert auf Mittelstand und lokale Dienstleister in Oberfranken.',
});

const localVsGenericRows = [
  {
    aspect: 'Zielsetzung',
    local: 'Top-3 im Google Maps-Pack für „[Branche] Coburg" oder „[Branche] Oberfranken"',
    generic: 'Sichtbarkeit für allgemeine Suchbegriffe ohne Stadtbezug',
  },
  {
    aspect: 'Wichtigster Hebel',
    local: 'Google Business Profile + lokale Citations + Bewertungen',
    generic: 'Content-Tiefe + Backlinks + technisches SEO',
  },
  {
    aspect: 'Wettbewerbssituation',
    local: 'Meist 5–15 Mitbewerber pro Coburger Branche',
    generic: 'Hunderte bis Tausende deutschlandweit',
  },
  {
    aspect: 'Time-to-Result',
    local: 'Erste Effekte nach 4–8 Wochen',
    generic: '6–12 Monate, oft länger',
  },
  {
    aspect: 'Sinnvolles Budget',
    local: '600–1.000 €/Monat',
    generic: 'Ab 2.000–5.000 €/Monat realistisch',
  },
  {
    aspect: 'Zielgruppe',
    local: 'Lokale Dienstleister, Handwerk, Gastronomie, Praxen, Kanzleien',
    generic: 'Online-Shops, B2B-SaaS, deutschlandweite Marken',
  },
];
---

<PageLayout title={seo.title} description={seo.description}>
  <JsonLd schema={buildService({ name: service.shortTitle, description: service.description, url: service.href })} />
  <JsonLd schema={buildFaqPage(faqs)} />

  <!-- Hero -->
  <Hero
    badge="SEO"
    headline="SEO — der Service im Überblick"
    subheadline="Suchmaschinenoptimierung mit Fokus auf lokale Sichtbarkeit. Audit, laufende Betreuung oder Full-Service — drei Einstiegsformen, abhängig von Ziel und Budget. Ohne Knebelverträge, mit verständlichen Reports."
    primaryCta={{ text: 'Erstgespräch vereinbaren', href: '/kontakt' }}
    secondaryCta={{ text: 'Preise ansehen', href: '#preise' }}
  />

  <!-- Features -->
  <section class="section">
    <div class="container">
      <div class="mx-auto max-w-3xl">
        <span class="section-label">Leistungen</span>
        <h2 class="mb-4">Was umfasst SEO bei mir?</h2>
        <p class="mb-12 text-lg text-neutral-600 leading-relaxed">
          SEO ist eine Mischung aus technischer Hygiene, Inhaltsarbeit und Vertrauensaufbau.
          Sieben Bausteine bilden das Standard-Repertoire — je nach Paket sind alle
          oder ausgewählte enthalten:
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {service.features.map((feature, index) => (
          <div class="card">
            <span class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 font-display text-lg font-bold text-accent">
              {String(index + 1).padStart(2, '0')}
            </span>
            <h3 class="mb-2">{feature.title}</h3>
            <p class="text-neutral-600 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Local vs Generic SEO Section (NEW) -->
  <section class="section relative bg-neutral-100 overflow-hidden">
    <GridPattern variant="dots" class="absolute inset-0" />
    <div class="container relative z-10">
      <div class="mx-auto max-w-3xl">
        <span class="section-label">Local vs. Generic</span>
        <h2 class="mb-4">Local SEO oder klassisches SEO — was passt zu Ihrem Unternehmen?</h2>
        <p class="mb-10 text-lg text-neutral-600 leading-relaxed">
          Wer in Coburg eine Praxis betreibt, braucht andere SEO-Schwerpunkte
          als ein deutschlandweiter Online-Shop. Bevor wir loslegen, kläre ich
          mit Ihnen, welche der beiden Strategien zu Ihrem Geschäftsmodell passt —
          oder ob eine Mischung sinnvoll ist.
        </p>
      </div>

      <div class="mx-auto max-w-4xl overflow-x-auto">
        <table class="w-full border-collapse text-left">
          <thead>
            <tr class="border-b-2 border-neutral-300">
              <th class="px-4 py-3 font-display text-sm font-semibold text-primary">Aspekt</th>
              <th class="px-4 py-3 font-display text-sm font-semibold text-accent">Local SEO</th>
              <th class="px-4 py-3 font-display text-sm font-semibold text-neutral-700">Klassisches SEO</th>
            </tr>
          </thead>
          <tbody>
            {localVsGenericRows.map((row) => (
              <tr class="border-b border-neutral-200">
                <td class="px-4 py-4 font-display text-sm font-semibold text-primary">{row.aspect}</td>
                <td class="px-4 py-4 text-small text-neutral-700">{row.local}</td>
                <td class="px-4 py-4 text-small text-neutral-700">{row.generic}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mx-auto mt-10 max-w-3xl text-center text-neutral-600 leading-relaxed">
        <strong class="font-semibold text-primary">Mein Schwerpunkt:</strong>{' '}
        Local SEO für Mittelstand und lokale Dienstleister in Oberfranken.
        Bei deutschlandweiten Online-Shops oder B2B-SaaS empfehle ich gezielt
        Kollegen mit dem entsprechenden Spezial-Fokus — ehrlicher als ein
        halbgares Allround-Angebot.
      </p>
    </div>
  </section>

  <!-- Pricing -->
  <PricingTiers
    intro={pricing.intro}
    tiers={pricing.tiers}
    footnote={pricing.footnote}
    anchorId="preise"
  />

  <!-- USPs renamed -->
  <section class="section">
    <div class="container">
      <div class="mx-auto max-w-3xl">
        <span class="section-label">Warum bei mir</span>
        <h2 class="mb-4">Warum SEO bei Digitalwerk?</h2>
        <p class="mb-10 text-lg text-neutral-600 leading-relaxed">
          Vier Punkte, die viele SEO-Anbieter entweder gar nicht haben oder
          die zumindest nicht zum Standard gehören:
        </p>

        <ul class="space-y-4">
          {service.usps.map((usp) => (
            <li class="flex items-start gap-3">
              <CheckCircle class="mt-0.5 h-6 w-6 shrink-0 text-success" />
              <span class="text-lg">{usp}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Deliverables renamed -->
  <section class="section bg-neutral-100">
    <div class="container">
      <div class="mx-auto max-w-3xl">
        <span class="section-label">Lieferumfang</span>
        <h2 class="mb-4">Was Sie monatlich von mir bekommen</h2>

        <span class="mb-4 inline-block rounded-full bg-accent/10 px-4 py-1.5 font-display text-sm font-semibold text-accent">
          {service.ctaText}
        </span>
        <p class="mb-8 text-neutral-600 leading-relaxed">
          Standardlieferumfang im Local-SEO-Paket. Bei Audit nur einmalig, bei
          Full-Service ergänzt um Content-Erstellung und aktiven Backlink-Aufbau:
        </p>

        <ul class="space-y-3">
          {service.deliverables.map((item) => (
            <li class="flex items-start gap-3">
              <CheckCircle class="mt-0.5 h-5 w-5 shrink-0 text-accent" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Stadt-LP-Verweis -->
  <section class="section py-12">
    <div class="container">
      <div class="mx-auto max-w-3xl rounded-card border border-accent/30 bg-accent/5 p-6 sm:p-8">
        <h3 class="mb-2">Sie suchen SEO speziell für Coburg, Bamberg oder Kronach?</h3>
        <p class="mb-4 text-neutral-600 leading-relaxed">
          Auf den Stadt-Landingpages für <strong>SEO Coburg</strong>,
          <strong>SEO Bamberg</strong> und <strong>SEO Kronach</strong>{' '}
          finden Sie Wettbewerbsanalysen, lokale Branchenbeispiele und
          stadtspezifische Antworten zu Google Business Profile und lokaler Sichtbarkeit.
        </p>
        <a href="/seo-coburg" class="btn-link">
          SEO Coburg ansehen &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-neutral-100">
    <div class="container">
      <FAQ title="Häufige Fragen zu SEO" items={faqs} />
    </div>
  </section>

  <!-- CTA -->
  <CTA
    headline="Bereit, bei Google sichtbar zu werden?"
    subline="Im kostenlosen 30-Minuten-Erstgespräch analysieren wir Ihren aktuellen Stand und identifizieren die größten Hebel. Danach wissen Sie, ob SEO sich für Sie lohnt — und in welchem Umfang."
  />
</PageLayout>
