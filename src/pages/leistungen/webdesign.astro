---
import PageLayout from '@layouts/PageLayout.astro';
import { getServiceBySlug } from '@data/services';
import { serviceFaqs } from '@data/faqs';
import { buildSeoMeta } from '@utils/seo';
import { buildService, buildFaqPage } from '@utils/schema';
import { getServicePricing } from '@data/service-pricing';
import JsonLd from '@components/seo/JsonLd.astro';
import Hero from '@components/sections/Hero.astro';
import FAQ from '@components/sections/FAQ.astro';
import PricingTiers from '@components/sections/PricingTiers.astro';
import CTA from '@components/ui/CTA.astro';
import { CheckCircle } from 'lucide-astro';
import GridPattern from '@components/decorative/GridPattern.astro';

const service = getServiceBySlug('webdesign')!;
const faqs = serviceFaqs['webdesign'] || [];
const pricing = getServicePricing('webdesign')!;

const seo = buildSeoMeta({
  title: 'Webdesign — der Service im Überblick',
  description:
    'Webdesign-Leistungen aus Coburg: Festpreise ab 3.000 €, Konzept bis Go-Live in 4–6 Wochen, persönliche Betreuung. Drei Standardpakete für Mittelstand, Handwerk und Praxen.',
});

const comparisons = [
  {
    title: 'Solo-Freelancer (das hier)',
    pros: [
      'Direkter Kontakt — kein Account-Manager',
      'Festpreise statt Tagessatz-Risiko',
      'Persönliche Treffen vor Ort möglich',
      'Code und Zugänge gehören Ihnen',
    ],
    cons: [
      'Kein 24/7-Notdienst',
      'Bei Krankheit kürzere Reaktionszeit',
      'Keine Marketing-Strategie aus einer Hand (nur Webdesign + SEO)',
    ],
  },
  {
    title: 'Agentur (10–50 MA)',
    pros: [
      'Notdienst möglich',
      'Spezialisten für jedes Detail',
      'Skalierbar bei großen Projekten',
    ],
    cons: [
      'Account-Manager als Mittelschicht',
      'Tagessätze meist 1.200 €+',
      'Junior-Entwickler:innen umsetzen',
      'Komplexere Vertragslage',
    ],
  },
  {
    title: 'Baukasten (Wix, Jimdo)',
    pros: [
      'Sofort startklar',
      'Niedrige laufende Kosten',
      'Keine technischen Vorkenntnisse nötig',
    ],
    cons: [
      'Begrenzte Designfreiheit',
      'SEO-Schwächen durch generische Templates',
      'Performance-Defizite',
      'Vendor-Lock-in: kein Wechsel ohne Neuaufbau',
    ],
  },
];
---

<PageLayout title={seo.title} description={seo.description}>
  <JsonLd schema={buildService({ name: service.shortTitle, description: service.description, url: service.href })} />
  <JsonLd schema={buildFaqPage(faqs)} />

  <!-- Hero -->
  <Hero
    badge="Webdesign"
    headline="Webdesign — der Service im Überblick"
    subheadline="Individuelles Webdesign mit klarer Conversion-Logik. Drei Festpreis-Pakete für Mittelstand, Handwerk und Praxen — keine Tagessatz-Falle, keine versteckten Posten, in 4–6 Wochen online."
    primaryCta={{ text: 'Erstgespräch vereinbaren', href: '/kontakt' }}
    secondaryCta={{ text: 'Preise ansehen', href: '#preise' }}
  />

  <!-- Features -->
  <section class="section">
    <div class="container">
      <div class="mx-auto max-w-3xl">
        <span class="section-label">Leistungen</span>
        <h2 class="mb-4">Was umfasst Webdesign bei mir?</h2>
        <p class="mb-12 text-lg text-neutral-600 leading-relaxed">
          Webdesign-Projekte folgen bei mir einer klaren Logik: Erst verstehen,
          was Ihre Website konkret leisten soll — Anfragen, Termine, Bestellungen,
          Vertrauen — dann gestalten und entwickeln. Sieben Bausteine sind in
          jedem Festpreis-Paket enthalten oder als Add-on buchbar:
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {service.features.map((feature, index) => (
          <div class="card">
            <span class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 font-display text-lg font-bold text-accent">
              {String(index + 1).padStart(2, '0')}
            </span>
            <h3 class="mb-2">{feature.title}</h3>
            <p class="text-neutral-600 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <PricingTiers
    intro={pricing.intro}
    tiers={pricing.tiers}
    footnote={pricing.footnote}
    anchorId="preise"
  />

  <!-- Comparison Section (NEW) -->
  <section class="section relative bg-neutral-100 overflow-hidden">
    <GridPattern variant="dots" class="absolute inset-0" />
    <div class="container relative z-10">
      <div class="mx-auto max-w-3xl">
        <span class="section-label">Im Vergleich</span>
        <h2 class="mb-4">Wann lohnt sich ein Solo-Freelancer statt Agentur oder Baukasten?</h2>
        <p class="mb-10 text-lg text-neutral-600 leading-relaxed">
          Je nach Größe, Anspruch und Budget sind unterschiedliche Modelle
          sinnvoll. Mein Angebot ist eine bestimmte Klasse — nicht für jeden,
          aber dafür für die Mehrheit der mittelständischen Coburger Betriebe
          die richtige Wahl. Ehrliche Gegenüberstellung:
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {comparisons.map((c) => (
          <article class="card p-6">
            <h3 class="font-display text-lg font-semibold text-primary">{c.title}</h3>

            <div class="mt-4">
              <p class="font-display text-xs font-semibold uppercase tracking-wider text-success">Stärken</p>
              <ul class="mt-2 space-y-1.5">
                {c.pros.map((p) => (
                  <li class="flex items-start gap-2 text-small text-neutral-700">
                    <span class="mt-0.5 text-success">+</span>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="mt-4">
              <p class="font-display text-xs font-semibold uppercase tracking-wider text-neutral-500">Grenzen</p>
              <ul class="mt-2 space-y-1.5">
                {c.cons.map((co) => (
                  <li class="flex items-start gap-2 text-small text-neutral-600">
                    <span class="mt-0.5 text-neutral-400">−</span>
                    <span>{co}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>

      <p class="mx-auto mt-10 max-w-3xl text-center text-neutral-600 leading-relaxed">
        Faustregel: Für 5–25 Mitarbeitende, mittlere Komplexität und klare
        Anforderungen passt der Solo-Freelancer fast immer am besten. Bei
        Konzernen oder hochkomplexen Plattformen ist eine spezialisierte
        Agentur die richtige Wahl.
      </p>
    </div>
  </section>

  <!-- USPs renamed -->
  <section class="section">
    <div class="container">
      <div class="mx-auto max-w-3xl">
        <span class="section-label">Warum bei mir</span>
        <h2 class="mb-4">Warum Webdesign bei Digitalwerk?</h2>
        <p class="mb-10 text-lg text-neutral-600 leading-relaxed">
          Vier Punkte, die Sie bei den meisten Wettbewerbern entweder gar nicht
          oder nur gegen Aufpreis bekommen:
        </p>

        <ul class="space-y-4">
          {service.usps.map((usp) => (
            <li class="flex items-start gap-3">
              <CheckCircle class="mt-0.5 h-6 w-6 shrink-0 text-success" />
              <span class="text-lg">{usp}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Deliverables renamed -->
  <section class="section bg-neutral-100">
    <div class="container">
      <div class="mx-auto max-w-3xl">
        <span class="section-label">Lieferumfang</span>
        <h2 class="mb-4">Was Sie nach Projektabschluss bekommen</h2>

        <span class="mb-4 inline-block rounded-full bg-accent/10 px-4 py-1.5 font-display text-sm font-semibold text-accent">
          {service.ctaText}
        </span>
        <p class="mb-8 text-neutral-600 leading-relaxed">
          Die folgende Liste ist im Standard-Paket enthalten. Premium ergänzt
          erweiterte Funktionen, Basis spart einzelne Punkte ein:
        </p>

        <ul class="space-y-3">
          {service.deliverables.map((item) => (
            <li class="flex items-start gap-3">
              <CheckCircle class="mt-0.5 h-5 w-5 shrink-0 text-accent" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Stadt-LP-Verweis -->
  <section class="section py-12">
    <div class="container">
      <div class="mx-auto max-w-3xl rounded-card border border-accent/30 bg-accent/5 p-6 sm:p-8">
        <h3 class="mb-2">Sie sind aus Coburg, Bamberg oder Lichtenfels?</h3>
        <p class="mb-4 text-neutral-600 leading-relaxed">
          Auf den Stadt-Landingpages für <strong>Webdesign Coburg</strong>,
          <strong>Webdesign Bamberg</strong> und <strong>Webdesign Lichtenfels</strong>
          finden Sie konkrete lokale Beispielprojekte, regionale Wirtschaftsbezüge
          und stadtspezifische FAQs.
        </p>
        <a href="/webdesign-coburg" class="btn-link">
          Webdesign Coburg ansehen &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-neutral-100">
    <div class="container">
      <FAQ title="Häufige Fragen zu Webdesign" items={faqs} />
    </div>
  </section>

  <!-- CTA -->
  <CTA
    headline="Bereit für Ihre neue Website?"
    subline="Im kostenlosen Erstgespräch klären wir in 30 Minuten, welches Paket zu Ihrem Anliegen passt — und ob ich der richtige Partner für Sie bin. Ergebnisoffen, ohne Verkaufsdruck."
  />
</PageLayout>
