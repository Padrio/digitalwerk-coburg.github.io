---
interface Props {
  headline: string;
  subheadline: string;
  primaryCta?: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
  badge?: string;
  stats?: Array<{ value: string; label: string }>;
  variant?: 'centered' | 'split';
}

const {
  headline,
  subheadline,
  primaryCta,
  secondaryCta,
  badge,
  stats,
  variant = 'centered',
} = Astro.props;
---

<section
  class="relative min-h-[85vh] flex items-center overflow-hidden"
  style="background: linear-gradient(135deg, #0a1128, #0f1d3d, #1e3a6e);"
>
  {/* Decorative orange radial glow */}
  <div
    class="pointer-events-none absolute right-[-10%] top-[20%] h-[500px] w-[500px] rounded-full opacity-15"
    style="background: radial-gradient(circle, #e8620a 0%, transparent 70%);"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute bottom-[-5%] left-[10%] h-[300px] w-[300px] rounded-full opacity-10"
    style="background: radial-gradient(circle, #e8620a 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="container relative z-10 py-20">
    {variant === 'centered' ? (
      <div class="mx-auto max-w-3xl text-center">
        {badge && (
          <div class="mb-6 flex justify-center">
            <span class="section-label text-white/80 before:bg-accent">
              {badge}
            </span>
          </div>
        )}

        <h1 class="display-text text-white">{headline}</h1>

        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-white/80">
          {subheadline}
        </p>

        {(primaryCta || secondaryCta) && (
          <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
            {primaryCta && (
              <a href={primaryCta.href} class="btn-primary">
                {primaryCta.text}
              </a>
            )}
            {secondaryCta && (
              <a
                href={secondaryCta.href}
                class="btn-outline border-white/30 text-white hover:bg-white/10 hover:text-white"
              >
                {secondaryCta.text}
              </a>
            )}
          </div>
        )}

        {stats && stats.length > 0 && (
          <div class="mt-16 flex flex-wrap items-center justify-center gap-8 border-t border-white/10 pt-10 sm:gap-12">
            {stats.map((stat) => (
              <div class="text-center">
                <div class="font-display text-3xl font-bold text-white sm:text-4xl">
                  {stat.value}
                </div>
                <div class="mt-1 text-small text-white/60">{stat.label}</div>
              </div>
            ))}
          </div>
        )}
      </div>
    ) : (
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          {badge && (
            <span class="section-label text-white/80 before:bg-accent">
              {badge}
            </span>
          )}

          <h1 class="display-text text-white">{headline}</h1>

          <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/80">
            {subheadline}
          </p>

          {(primaryCta || secondaryCta) && (
            <div class="mt-10 flex flex-wrap items-center gap-4">
              {primaryCta && (
                <a href={primaryCta.href} class="btn-primary">
                  {primaryCta.text}
                </a>
              )}
              {secondaryCta && (
                <a
                  href={secondaryCta.href}
                  class="btn-outline border-white/30 text-white hover:bg-white/10 hover:text-white"
                >
                  {secondaryCta.text}
                </a>
              )}
            </div>
          )}

          {stats && stats.length > 0 && (
            <div class="mt-14 flex flex-wrap items-center gap-8 border-t border-white/10 pt-8">
              {stats.map((stat) => (
                <div>
                  <div class="font-display text-3xl font-bold text-white">
                    {stat.value}
                  </div>
                  <div class="mt-1 text-small text-white/60">{stat.label}</div>
                </div>
              ))}
            </div>
          )}
        </div>

        <div class="flex items-center justify-center">
          <slot />
        </div>
      </div>
    )}
  </div>
</section>
