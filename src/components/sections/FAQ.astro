---
import JsonLd from '@components/seo/JsonLd.astro';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title } = Astro.props;

// Generate FAQPage structured data
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<JsonLd schema={faqSchema} />

<div class="faq">
  {title && (
    <h2 class="mb-8 text-center">{title}</h2>
  )}

  <div class="mx-auto max-w-3xl divide-y divide-neutral-100">
    {items.map((item) => (
      <details class="group">
        <summary class="flex cursor-pointer items-center justify-between gap-4 py-5 font-display text-lg font-semibold text-primary transition-colors hover:text-accent list-none [&::-webkit-details-marker]:hidden">
          <span>{item.question}</span>
          {/* Plus/minus indicator */}
          <span class="relative flex h-6 w-6 shrink-0 items-center justify-center" aria-hidden="true">
            {/* Horizontal bar (always visible) */}
            <span class="absolute h-0.5 w-3.5 rounded-full bg-accent"></span>
            {/* Vertical bar (hidden when open) */}
            <span class="absolute h-3.5 w-0.5 rounded-full bg-accent transition-transform duration-200 group-open:rotate-90 group-open:opacity-0"></span>
          </span>
        </summary>

        <div class="pb-5 pr-10 text-neutral-600 leading-relaxed">
          <p>{item.answer}</p>
        </div>
      </details>
    ))}
  </div>
</div>
