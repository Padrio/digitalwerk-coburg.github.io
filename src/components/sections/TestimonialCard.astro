---
interface Props {
  name: string;
  role: string;
  company: string;
  quote: string;
  rating: number;
  initials: string;
}

const { name, role, company, quote, rating, initials } = Astro.props;

const filledStars = Math.min(Math.max(Math.round(rating), 0), 5);
const emptyStars = 5 - filledStars;
---

<article class="card flex flex-col justify-between">
  {/* Star rating */}
  <div>
    <div class="mb-4 flex items-center gap-1" aria-label={`Bewertung: ${rating} von 5 Sternen`}>
      {Array.from({ length: filledStars }).map(() => (
        <svg
          class="h-5 w-5 text-accent"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
      {Array.from({ length: emptyStars }).map(() => (
        <svg
          class="h-5 w-5 text-neutral-300"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>

    {/* Quote */}
    <blockquote class="text-neutral-600 italic leading-relaxed">
      &ldquo;{quote}&rdquo;
    </blockquote>
  </div>

  {/* Author info */}
  <div class="mt-6 flex items-center gap-3 border-t border-neutral-100 pt-5">
    <div
      class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-primary font-display text-sm font-bold text-white"
      aria-hidden="true"
    >
      {initials}
    </div>
    <div>
      <div class="font-display text-sm font-semibold text-primary">{name}</div>
      <div class="text-small text-neutral-600">
        {role}, {company}
      </div>
    </div>
  </div>
</article>
