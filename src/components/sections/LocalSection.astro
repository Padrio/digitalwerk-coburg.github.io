---
const servedAreas = [
  'Coburg',
  'Bamberg',
  'Kronach',
  'Lichtenfels',
  'Sonneberg',
  'Hildburghausen',
  'Kulmbach',
  'Bayreuth',
];
---

<section class="section bg-neutral-100">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center">
      <span class="section-label justify-center">Regional verwurzelt</span>

      <h2>Ihr digitaler Partner aus Coburg</h2>

      <p class="mt-6 text-lg text-neutral-600 leading-relaxed">
        Wir sind kein anonymes Unternehmen aus der Ferne &ndash; wir sitzen direkt
        in Coburg, mitten in Oberfranken. Das bedeutet: kurze Wege,
        persönliche Treffen und ein tiefes Verständnis für die regionalen
        Besonderheiten Ihrer Branche und Ihres Marktes.
      </p>

      <p class="mt-4 text-neutral-600 leading-relaxed">
        Wir kennen die Herausforderungen und Chancen lokaler Unternehmen.
        Ob Handwerksbetrieb, Arztpraxis oder mittelständisches
        Fertigungsunternehmen &ndash; wir sprechen Ihre Sprache und verstehen
        Ihre Ziele. Persönlicher Kontakt und Verlässlichkeit sind für uns
        keine Floskeln, sondern gelebte Praxis.
      </p>
    </div>

    {/* Served areas */}
    <div class="mx-auto mt-12 max-w-2xl">
      <h3 class="mb-5 text-center font-display text-lg font-semibold text-primary">
        Unsere Region
      </h3>
      <div class="flex flex-wrap items-center justify-center gap-3">
        {servedAreas.map((area) => (
          <span class="inline-flex items-center gap-1.5 rounded-full border border-neutral-300 bg-white px-4 py-1.5 font-display text-small font-medium text-primary">
            <svg
              class="h-3.5 w-3.5 text-accent"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                clip-rule="evenodd"
              />
            </svg>
            {area}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
