---
import { footerNav } from '@data/navigation';
import { services } from '@data/services';
import { SITE } from '@data/site';

const leistungenGroup = footerNav.find((g) => g.category === 'Leistungen');
const unternehmenGroup = footerNav.find((g) => g.category === 'Unternehmen');
const currentYear = new Date().getFullYear();
---

<footer class="relative overflow-hidden" style="background: linear-gradient(135deg, #0a1128 0%, #0f1d3d 100%);">
  <!-- Decorative orange radial glow -->
  <div
    class="pointer-events-none absolute -right-32 -top-32 h-[500px] w-[500px] opacity-[0.07]"
    style="background: radial-gradient(circle, #e8620a 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Main footer content -->
  <div class="container section relative z-10">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8">

      <!-- Column 1: Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="mb-6 inline-flex items-center gap-3 no-underline" aria-label="Digitalwerk Coburg - Startseite">
          <svg viewBox="0 0 48 48" fill="none" class="h-10 w-10 shrink-0" aria-hidden="true">
            <rect width="48" height="48" rx="10" fill="rgba(255,255,255,0.1)" />
            <text x="8" y="34" font-family="Georgia, serif" font-weight="800" font-size="30" fill="#ffffff">D</text>
            <rect x="30" y="12" width="4" height="24" rx="2" fill="#e8620a" />
            <rect x="36" y="18" width="4" height="18" rx="2" fill="#e8620a" opacity="0.6" />
          </svg>
          <div class="flex flex-col leading-none">
            <span class="font-display text-lg font-bold tracking-tight text-white">Digitalwerk</span>
            <span class="font-display text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-accent">Coburg</span>
          </div>
        </a>

        <p class="mb-4 font-display text-sm font-semibold tracking-wide text-white/90">
          {SITE.tagline}
        </p>
        <p class="text-sm leading-relaxed text-neutral-300">
          Ihr zuverlässiger Digitalpartner aus Coburg für Webdesign, Webentwicklung, SEO und KI-Beratung. Persönlich. Regional. Ergebnisorientiert.
        </p>
      </div>

      <!-- Column 2: Leistungen -->
      <div>
        <h3 class="mb-5 font-display text-sm font-semibold uppercase tracking-[0.1em] text-white">
          Leistungen
        </h3>
        <ul class="space-y-3">
          {services.map((service) => (
            <li>
              <a
                href={service.href}
                class="text-sm text-neutral-300 no-underline transition-colors duration-200 hover:text-white"
              >
                {service.shortTitle}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Navigation -->
      <div>
        <h3 class="mb-5 font-display text-sm font-semibold uppercase tracking-[0.1em] text-white">
          Navigation
        </h3>
        <ul class="space-y-3">
          {unternehmenGroup?.items.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-neutral-300 no-underline transition-colors duration-200 hover:text-white"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Kontakt -->
      <div>
        <h3 class="mb-5 font-display text-sm font-semibold uppercase tracking-[0.1em] text-white">
          Kontakt
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href={`mailto:${SITE.email}`}
              class="text-sm text-neutral-300 no-underline transition-colors duration-200 hover:text-white"
            >
              {SITE.email}
            </a>
          </li>
          <li>
            <a
              href={`tel:${SITE.phone.replace(/\s/g, '')}`}
              class="text-sm text-neutral-300 no-underline transition-colors duration-200 hover:text-white"
            >
              {SITE.phone}
            </a>
          </li>
          <li class="text-sm leading-relaxed text-neutral-300">
            {SITE.address.street}<br />
            {SITE.address.zip} {SITE.address.city}
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="relative z-10 border-t border-white/10">
    <div class="container flex flex-col items-center justify-between gap-4 py-6 sm:flex-row">
      <p class="text-sm text-neutral-300">
        &copy; {currentYear} {SITE.name}. Alle Rechte vorbehalten.
      </p>
      <nav class="flex gap-6" aria-label="Rechtliches">
        <a
          href="/impressum"
          class="text-sm text-neutral-300 no-underline transition-colors duration-200 hover:text-white"
        >
          Impressum
        </a>
        <a
          href="/datenschutz"
          class="text-sm text-neutral-300 no-underline transition-colors duration-200 hover:text-white"
        >
          Datenschutz
        </a>
      </nav>
    </div>
  </div>
</footer>
