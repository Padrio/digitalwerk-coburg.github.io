---
interface Props {
  headline: string;
  subline: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  headline,
  subline,
  buttonText = "Erstgespräch vereinbaren",
  buttonHref = "/kontakt",
} = Astro.props;
---

<section class="section relative overflow-hidden bg-gradient-to-br from-primary to-primary-light">
  <!-- Decorative radial glow -->
  <div
    class="pointer-events-none absolute -top-24 -right-24 h-96 w-96 rounded-full opacity-20"
    style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="container relative z-10 text-center">
    <h2 class="mb-4 text-white">{headline}</h2>
    <p class="mx-auto mb-8 max-w-2xl text-lg text-white/80">
      {subline}
    </p>
    <a href={buttonHref} class="btn-primary">
      {buttonText}
    </a>
  </div>
</section>
