---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  widths?: number[];
  sizes?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  variant?: 'default' | 'desaturated' | 'duotone' | 'monochrome';
  rounded?: boolean;
  shadow?: boolean;
}

const {
  src,
  alt,
  widths = [400, 800, 1200],
  sizes = '(max-width: 768px) 100vw, (max-width: 1100px) 50vw, 550px',
  class: className = '',
  loading = 'lazy',
  variant = 'default',
  rounded = true,
  shadow = false,
} = Astro.props;

const variantClasses: Record<string, string> = {
  default: 'image-desaturated',
  desaturated: 'image-desaturated',
  duotone: 'image-duotone',
  monochrome: 'image-monochrome-navy',
};

const imageClasses = [
  variantClasses[variant] || '',
  rounded ? 'rounded-card' : '',
  shadow ? 'image-shadow' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<Image
  src={src}
  alt={alt}
  widths={widths}
  sizes={sizes}
  class={imageClasses}
  loading={loading}
/>
