---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  heroImage?: string;
  tags?: string[];
}

const { title, description, pubDate, slug, heroImage, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("de-DE", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="card flex flex-col overflow-hidden p-0">
  {heroImage && (
    <a href={`/blog/${slug}`} class="block overflow-hidden">
      <img
        src={heroImage}
        alt={title}
        class="aspect-video w-full object-cover transition-transform duration-300 hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    </a>
  )}

  <div class="flex flex-1 flex-col p-6">
    <time
      datetime={pubDate.toISOString()}
      class="text-small text-neutral-600"
    >
      {formattedDate}
    </time>

    <h3 class="mt-2 mb-2">
      <a
        href={`/blog/${slug}`}
        class="text-primary no-underline transition-colors duration-200 hover:text-accent"
      >
        {title}
      </a>
    </h3>

    <p class="mb-4 flex-1 text-neutral-600 line-clamp-3">
      {description}
    </p>

    {tags && tags.length > 0 && (
      <div class="mb-4 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="inline-block rounded-full bg-neutral-100 px-3 py-0.5 text-xs font-medium text-neutral-600">
            {tag}
          </span>
        ))}
      </div>
    )}

    <a
      href={`/blog/${slug}`}
      class="btn-link mt-auto self-start"
    >
      Weiterlesen &rarr;
    </a>
  </div>
</article>
