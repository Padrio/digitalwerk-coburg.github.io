---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt?: string;
  overlayOpacity?: number;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt = '',
  overlayOpacity = 75,
  loading = 'eager',
} = Astro.props;

const opacityValue = Math.max(0, Math.min(100, 100 - overlayOpacity));
---

<div class="absolute inset-0 overflow-hidden">
  <Image
    src={src}
    alt={alt}
    widths={[960, 1440, 1920]}
    sizes="100vw"
    class:list={[
      'h-full w-full object-cover image-desaturated',
      `opacity-${opacityValue}`,
    ]}
    loading={loading}
  />
</div>
