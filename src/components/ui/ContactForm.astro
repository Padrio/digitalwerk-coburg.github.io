---
/**
 * Contact form with Formspree integration.
 * Shows a success message when ?success=true is present in the URL.
 */
const isSuccess = Astro.url.searchParams.get("success") === "true";
---

{isSuccess ? (
  <div class="rounded-[var(--radius-card)] border border-success/30 bg-success/10 p-8 text-center">
    <p class="text-lg font-semibold text-success">
      Vielen Dank f&uuml;r Ihre Nachricht!
    </p>
    <p class="mt-2 text-neutral-600">
      Wir melden uns in K&uuml;rze bei Ihnen.
    </p>
  </div>
) : (
  <form
    action="https://formspree.io/f/FORM_ID"
    method="POST"
    class="space-y-6"
  >
    <!-- Honeypot -->
    <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

    <!-- Name -->
    <div>
      <label for="contact-name" class="mb-1.5 block text-small font-semibold text-neutral-900">
        Name <span class="text-accent">*</span>
      </label>
      <input
        type="text"
        id="contact-name"
        name="name"
        required
        placeholder="Max Mustermann"
        class="w-full rounded-[var(--radius-btn)] border border-neutral-300 bg-white px-4 py-3 text-neutral-900 outline-none transition-colors duration-200 placeholder:text-neutral-300 focus:border-accent focus:ring-2 focus:ring-accent/20"
      />
    </div>

    <!-- Email -->
    <div>
      <label for="contact-email" class="mb-1.5 block text-small font-semibold text-neutral-900">
        E-Mail <span class="text-accent">*</span>
      </label>
      <input
        type="email"
        id="contact-email"
        name="email"
        required
        placeholder="max@beispiel.de"
        class="w-full rounded-[var(--radius-btn)] border border-neutral-300 bg-white px-4 py-3 text-neutral-900 outline-none transition-colors duration-200 placeholder:text-neutral-300 focus:border-accent focus:ring-2 focus:ring-accent/20"
      />
    </div>

    <!-- Telefon -->
    <div>
      <label for="contact-phone" class="mb-1.5 block text-small font-semibold text-neutral-900">
        Telefon
      </label>
      <input
        type="tel"
        id="contact-phone"
        name="telefon"
        placeholder="+49 123 456 789"
        class="w-full rounded-[var(--radius-btn)] border border-neutral-300 bg-white px-4 py-3 text-neutral-900 outline-none transition-colors duration-200 placeholder:text-neutral-300 focus:border-accent focus:ring-2 focus:ring-accent/20"
      />
    </div>

    <!-- Service-Auswahl -->
    <div>
      <label for="contact-service" class="mb-1.5 block text-small font-semibold text-neutral-900">
        Service-Auswahl
      </label>
      <select
        id="contact-service"
        name="service"
        class="w-full appearance-none rounded-[var(--radius-btn)] border border-neutral-300 bg-white px-4 py-3 text-neutral-900 outline-none transition-colors duration-200 focus:border-accent focus:ring-2 focus:ring-accent/20"
      >
        <option value="" disabled selected>Bitte w&auml;hlen...</option>
        <option value="webdesign">Webdesign &amp; Entwicklung</option>
        <option value="ecommerce">E-Commerce &amp; Online-Shop</option>
        <option value="seo">SEO &amp; Online-Marketing</option>
        <option value="branding">Branding &amp; Corporate Design</option>
        <option value="sonstiges">Sonstiges</option>
      </select>
    </div>

    <!-- Nachricht -->
    <div>
      <label for="contact-message" class="mb-1.5 block text-small font-semibold text-neutral-900">
        Nachricht <span class="text-accent">*</span>
      </label>
      <textarea
        id="contact-message"
        name="nachricht"
        required
        rows="5"
        placeholder="Beschreiben Sie kurz Ihr Anliegen..."
        class="w-full resize-y rounded-[var(--radius-btn)] border border-neutral-300 bg-white px-4 py-3 text-neutral-900 outline-none transition-colors duration-200 placeholder:text-neutral-300 focus:border-accent focus:ring-2 focus:ring-accent/20"
      ></textarea>
    </div>

    <!-- DSGVO -->
    <div class="flex items-start gap-3">
      <input
        type="checkbox"
        id="contact-dsgvo"
        name="dsgvo"
        required
        class="mt-1 h-4 w-4 shrink-0 cursor-pointer rounded border-neutral-300 accent-accent"
      />
      <label for="contact-dsgvo" class="text-small text-neutral-600">
        Ich habe die <a href="/datenschutz" class="text-accent underline hover:text-accent-hover">Datenschutzerkl&auml;rung</a> gelesen und stimme der Verarbeitung meiner Daten zu. <span class="text-accent">*</span>
      </label>
    </div>

    <!-- Submit -->
    <div>
      <button type="submit" class="btn-primary w-full sm:w-auto cursor-pointer">
        Nachricht senden
      </button>
    </div>
  </form>
)}
