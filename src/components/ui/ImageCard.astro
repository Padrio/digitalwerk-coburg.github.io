---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  aspectRatio?: '16:9' | '4:3' | '3:2' | '1:1';
  widths?: number[];
  sizes?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt,
  aspectRatio = '16:9',
  widths = [400, 800, 1200],
  sizes = '(max-width: 768px) 100vw, (max-width: 1100px) 50vw, 550px',
  class: className = '',
  loading = 'lazy',
} = Astro.props;

const aspectClasses: Record<string, string> = {
  '16:9': 'aspect-video',
  '4:3': 'aspect-4/3',
  '3:2': 'aspect-3/2',
  '1:1': 'aspect-square',
};
---

<div class:list={['overflow-hidden rounded-card bg-white image-shadow', className]}>
  <div class:list={[aspectClasses[aspectRatio] || 'aspect-video', 'relative']}>
    <Image
      src={src}
      alt={alt}
      widths={widths}
      sizes={sizes}
      class="absolute inset-0 h-full w-full object-cover image-desaturated"
      loading={loading}
    />
  </div>
  <slot />
</div>
