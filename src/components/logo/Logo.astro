---
interface Props {
  variant?: 'full' | 'mark' | 'wordmark';
  class?: string;
}

const { variant = 'full', class: className = '' } = Astro.props;
---

{variant === 'mark' && (
  <svg viewBox="0 0 48 48" fill="none" class={className} aria-hidden="true">
    <rect width="48" height="48" rx="10" fill="#0f1d3d" />
    <text x="8" y="34" font-family="Georgia, serif" font-weight="800" font-size="30" fill="#ffffff">D</text>
    <rect x="30" y="12" width="4" height="24" rx="2" fill="#e8620a" />
    <rect x="36" y="18" width="4" height="18" rx="2" fill="#e8620a" opacity="0.6" />
  </svg>
)}

{variant === 'full' && (
  <a href="/" class:list={["flex items-center gap-3 no-underline", className]} aria-label="Digitalwerk Coburg - Startseite">
    <svg viewBox="0 0 48 48" fill="none" class="h-10 w-10 shrink-0" aria-hidden="true">
      <rect width="48" height="48" rx="10" fill="#0f1d3d" />
      <text x="8" y="34" font-family="Georgia, serif" font-weight="800" font-size="30" fill="#ffffff">D</text>
      <rect x="30" y="12" width="4" height="24" rx="2" fill="#e8620a" />
      <rect x="36" y="18" width="4" height="18" rx="2" fill="#e8620a" opacity="0.6" />
    </svg>
    <div class="flex flex-col leading-none">
      <span class="font-display text-lg font-bold tracking-tight text-primary">Digitalwerk</span>
      <span class="font-display text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-accent">Coburg</span>
    </div>
  </a>
)}

{variant === 'wordmark' && (
  <a href="/" class:list={["flex flex-col leading-none no-underline", className]} aria-label="Digitalwerk Coburg - Startseite">
    <span class="font-display text-lg font-bold tracking-tight text-primary">Digitalwerk</span>
    <span class="font-display text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-accent">Coburg</span>
  </a>
)}
