---
/**
 * Hexagonal geometric pattern — technical, structured aesthetic.
 * Used as decorative background in dark sections (hero, CTA).
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<svg
  class:list={['pointer-events-none', className]}
  viewBox="0 0 600 400"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  {/* Hexagonal outlines */}
  <polygon points="100,40 140,20 180,40 180,80 140,100 100,80" stroke="rgba(255,255,255,0.06)" stroke-width="1" fill="none" />
  <polygon points="180,40 220,20 260,40 260,80 220,100 180,80" stroke="rgba(255,255,255,0.04)" stroke-width="1" fill="none" />
  <polygon points="260,40 300,20 340,40 340,80 300,100 260,80" stroke="rgba(255,255,255,0.06)" stroke-width="1" fill="none" />
  <polygon points="340,40 380,20 420,40 420,80 380,100 340,80" stroke="rgba(255,255,255,0.03)" stroke-width="1" fill="none" />
  <polygon points="420,40 460,20 500,40 500,80 460,100 420,80" stroke="rgba(255,255,255,0.05)" stroke-width="1" fill="none" />

  <polygon points="140,100 180,80 220,100 220,140 180,160 140,140" stroke="rgba(255,255,255,0.04)" stroke-width="1" fill="none" />
  <polygon points="220,100 260,80 300,100 300,140 260,160 220,140" stroke="rgba(255,255,255,0.07)" stroke-width="1" fill="none" />
  <polygon points="300,100 340,80 380,100 380,140 340,160 300,140" stroke="rgba(255,255,255,0.04)" stroke-width="1" fill="none" />
  <polygon points="380,100 420,80 460,100 460,140 420,160 380,140" stroke="rgba(255,255,255,0.06)" stroke-width="1" fill="none" />

  <polygon points="100,160 140,140 180,160 180,200 140,220 100,200" stroke="rgba(255,255,255,0.05)" stroke-width="1" fill="none" />
  <polygon points="180,160 220,140 260,160 260,200 220,220 180,200" stroke="rgba(255,255,255,0.04)" stroke-width="1" fill="none" />
  <polygon points="260,160 300,140 340,160 340,200 300,220 260,200" stroke="rgba(255,255,255,0.06)" stroke-width="1" fill="none" />
  <polygon points="340,160 380,140 420,160 420,200 380,220 340,200" stroke="rgba(255,255,255,0.05)" stroke-width="1" fill="none" />
  <polygon points="420,160 460,140 500,160 500,200 460,220 420,200" stroke="rgba(255,255,255,0.03)" stroke-width="1" fill="none" />

  <polygon points="140,220 180,200 220,220 220,260 180,280 140,260" stroke="rgba(255,255,255,0.04)" stroke-width="1" fill="none" />
  <polygon points="220,220 260,200 300,220 300,260 260,280 220,260" stroke="rgba(255,255,255,0.05)" stroke-width="1" fill="none" />
  <polygon points="300,220 340,200 380,220 380,260 340,280 300,260" stroke="rgba(255,255,255,0.06)" stroke-width="1" fill="none" />
  <polygon points="380,220 420,200 460,220 460,260 420,280 380,260" stroke="rgba(255,255,255,0.04)" stroke-width="1" fill="none" />

  <polygon points="100,280 140,260 180,280 180,320 140,340 100,320" stroke="rgba(255,255,255,0.03)" stroke-width="1" fill="none" />
  <polygon points="180,280 220,260 260,280 260,320 220,340 180,320" stroke="rgba(255,255,255,0.06)" stroke-width="1" fill="none" />
  <polygon points="260,280 300,260 340,280 340,320 300,340 260,320" stroke="rgba(255,255,255,0.04)" stroke-width="1" fill="none" />
  <polygon points="340,280 380,260 420,280 420,320 380,340 340,320" stroke="rgba(255,255,255,0.05)" stroke-width="1" fill="none" />
  <polygon points="420,280 460,260 500,280 500,320 460,340 420,320" stroke="rgba(255,255,255,0.06)" stroke-width="1" fill="none" />

  {/* Accent highlight on one hexagon */}
  <polygon points="260,160 300,140 340,160 340,200 300,220 260,200" stroke="rgba(232,98,10,0.12)" stroke-width="1.5" fill="rgba(232,98,10,0.03)" />
</svg>
