---
/**
 * Isometric block/device illustration — abstract representation
 * of digital work (website layouts, screens, data blocks).
 * Matches the "Ingenieurbüro" aesthetic: technical but not cold.
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<svg
  class:list={['pointer-events-none', className]}
  viewBox="0 0 400 360"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  {/* Back panel (monitor/screen) */}
  <path d="M80 60 L320 60 L320 220 L80 220 Z" rx="8" fill="#0f1d3d" stroke="#1e3a6e" stroke-width="1.5" />
  <rect x="90" y="70" width="220" height="140" rx="4" fill="#0a1128" />

  {/* Screen content lines (website wireframe) */}
  <rect x="105" y="85" width="80" height="8" rx="2" fill="#1e3a6e" />
  <rect x="105" y="100" width="190" height="4" rx="1" fill="rgba(30,58,110,0.5)" />
  <rect x="105" y="110" width="160" height="4" rx="1" fill="rgba(30,58,110,0.4)" />
  <rect x="105" y="120" width="175" height="4" rx="1" fill="rgba(30,58,110,0.3)" />

  {/* Orange accent element (button/CTA on screen) */}
  <rect x="105" y="140" width="60" height="16" rx="3" fill="#e8620a" opacity="0.8" />

  {/* Content blocks */}
  <rect x="105" y="168" width="55" height="30" rx="3" fill="rgba(30,58,110,0.3)" />
  <rect x="168" y="168" width="55" height="30" rx="3" fill="rgba(30,58,110,0.25)" />
  <rect x="231" y="168" width="55" height="30" rx="3" fill="rgba(30,58,110,0.2)" />

  {/* Monitor stand */}
  <path d="M180 220 L220 220 L230 250 L170 250 Z" fill="#0f1d3d" />
  <rect x="155" y="250" width="90" height="6" rx="3" fill="#1e3a6e" />

  {/* Floating elements (abstract data/code blocks) */}
  <rect x="330" y="90" width="50" height="50" rx="6" fill="#1e3a6e" opacity="0.4" transform="rotate(12 355 115)" />
  <rect x="340" y="170" width="35" height="35" rx="4" fill="#e8620a" opacity="0.15" transform="rotate(-8 357 187)" />
  <rect x="10" y="120" width="45" height="45" rx="6" fill="#1e3a6e" opacity="0.3" transform="rotate(-15 32 142)" />
  <circle cx="40" cy="80" r="8" fill="#e8620a" opacity="0.1" />
  <circle cx="360" cy="60" r="6" fill="#1e3a6e" opacity="0.3" />

  {/* Connection dots */}
  <circle cx="345" cy="135" r="2.5" fill="#e8620a" opacity="0.5" />
  <circle cx="25" cy="170" r="2" fill="#1e3a6e" opacity="0.5" />
</svg>
