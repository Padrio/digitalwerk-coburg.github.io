---
/**
 * Abstract network pattern (connected nodes & edges).
 * Used as decorative background element in sections.
 * Style: geometric, technical, structured — matching "Ingenieurbüro" character.
 */
interface Props {
  class?: string;
  variant?: 'light' | 'dark';
}

const { class: className = '', variant = 'dark' } = Astro.props;

const colors = {
  dark: {
    line: 'rgba(30, 58, 110, 0.3)',
    dot: '#1e3a6e',
    accent: '#e8620a',
  },
  light: {
    line: 'rgba(255, 255, 255, 0.08)',
    dot: 'rgba(255, 255, 255, 0.15)',
    accent: 'rgba(232, 98, 10, 0.4)',
  },
};

const c = colors[variant];
---

<svg
  class:list={['pointer-events-none', className]}
  viewBox="0 0 800 600"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  {/* Connection lines */}
  <line x1="120" y1="80" x2="280" y2="160" stroke={c.line} stroke-width="1" />
  <line x1="280" y1="160" x2="460" y2="120" stroke={c.line} stroke-width="1" />
  <line x1="460" y1="120" x2="620" y2="200" stroke={c.line} stroke-width="1" />
  <line x1="620" y1="200" x2="720" y2="100" stroke={c.line} stroke-width="1" />
  <line x1="280" y1="160" x2="320" y2="320" stroke={c.line} stroke-width="1" />
  <line x1="320" y1="320" x2="500" y2="360" stroke={c.line} stroke-width="1" />
  <line x1="500" y1="360" x2="620" y2="200" stroke={c.line} stroke-width="1" />
  <line x1="120" y1="80" x2="80" y2="280" stroke={c.line} stroke-width="1" />
  <line x1="80" y1="280" x2="320" y2="320" stroke={c.line} stroke-width="1" />
  <line x1="500" y1="360" x2="680" y2="440" stroke={c.line} stroke-width="1" />
  <line x1="460" y1="120" x2="500" y2="360" stroke={c.line} stroke-width="1" />
  <line x1="80" y1="280" x2="200" y2="460" stroke={c.line} stroke-width="1" />
  <line x1="200" y1="460" x2="400" y2="500" stroke={c.line} stroke-width="1" />
  <line x1="400" y1="500" x2="500" y2="360" stroke={c.line} stroke-width="1" />
  <line x1="400" y1="500" x2="680" y2="440" stroke={c.line} stroke-width="1" />

  {/* Network nodes */}
  <circle cx="120" cy="80" r="4" fill={c.dot} />
  <circle cx="280" cy="160" r="5" fill={c.dot} />
  <circle cx="460" cy="120" r="4" fill={c.dot} />
  <circle cx="620" cy="200" r="5" fill={c.accent} />
  <circle cx="720" cy="100" r="3" fill={c.dot} />
  <circle cx="320" cy="320" r="4" fill={c.dot} />
  <circle cx="500" cy="360" r="5" fill={c.dot} />
  <circle cx="80" cy="280" r="3" fill={c.dot} />
  <circle cx="680" cy="440" r="4" fill={c.accent} />
  <circle cx="200" cy="460" r="3" fill={c.dot} />
  <circle cx="400" cy="500" r="4" fill={c.dot} />
</svg>
